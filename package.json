{
  "name": "any-markdown",
  "displayName": "Any Markdown Editor",
  "description": "A WYSIWYG markdown editor for VS Code with seamless live preview",
  "version": "0.195.506",
  "publisher": "imaken",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/raggbal/any-markdown"
  },
  "bugs": {
    "url": "https://github.com/raggbal/any-markdown/issues"
  },
  "homepage": "https://github.com/raggbal/any-markdown#readme",
  "sponsor": {
    "url": "https://github.com/sponsors/raggbal"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Visualization"
  ],
  "keywords": [
    "markdown",
    "wysiwyg",
    "editor",
    "live preview",
    "mermaid",
    "table",
    "rich text"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "any-markdown-notes",
          "title": "Any Markdown Notes",
          "icon": "media/notes-icon.svg"
        }
      ]
    },
    "views": {
      "any-markdown-notes": [
        {
          "id": "notesExplorer",
          "name": "Notes Folders"
        }
      ]
    },
    "commands": [
      {
        "command": "any-markdown.openEditor",
        "title": "Open with Any Markdown Editor",
        "category": "Any MD"
      },
      {
        "command": "any-markdown.addNotesFolder",
        "title": "Add Notes Folder",
        "category": "Any MD",
        "icon": "$(add)"
      },
      {
        "command": "any-markdown.removeNotesFolder",
        "title": "Remove Notes Folder",
        "category": "Any MD",
        "icon": "$(remove)"
      },
      {
        "command": "any-markdown.openNotesFolder",
        "title": "Open Notes Folder",
        "category": "Any MD"
      },
      {
        "command": "any-markdown.exportToPdf",
        "title": "Export to PDF",
        "category": "Any MD"
      },
      {
        "command": "any-markdown.insertTable",
        "title": "Insert Table",
        "category": "Any MD"
      },
      {
        "command": "any-markdown.insertToc",
        "title": "Insert Table of Contents",
        "category": "Any MD"
      },
      {
        "command": "any-markdown.openAsText",
        "title": "Open as Text Editor",
        "category": "Any MD"
      },
      {
        "command": "any-markdown.toggleSourceMode",
        "title": "Toggle Source Mode",
        "category": "Any MD"
      },
      {
        "command": "any-markdown.compareAsText",
        "title": "Compare as Text",
        "category": "Any MD"
      },
      {
        "command": "any-markdown.undo",
        "title": "Undo",
        "category": "Any MD"
      },
      {
        "command": "any-markdown.redo",
        "title": "Redo",
        "category": "Any MD"
      },
      {
        "command": "any-markdown.scopeIn",
        "title": "Scope Into Node",
        "category": "Any MD"
      },
      {
        "command": "any-markdown.scopeOut",
        "title": "Clear Scope",
        "category": "Any MD"
      },
      {
        "command": "any-markdown.newOutliner",
        "title": "New Outliner File",
        "category": "Any MD"
      }
    ],
    "customEditors": [
      {
        "viewType": "any-markdown.editor",
        "displayName": "Any Markdown",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "any-markdown.outliner",
        "displayName": "Any Markdown Outliner",
        "selector": [
          {
            "filenamePattern": "*.out"
          }
        ],
        "priority": "default"
      }
    ],
    "configuration": {
      "title": "Any Markdown",
      "properties": {
        "any-markdown.theme": {
          "type": "string",
          "enum": [
            "github",
            "sepia",
            "night",
            "dark",
            "minimal",
            "perplexity",
            "things"
          ],
          "default": "things",
          "description": "Editor theme"
        },
        "any-markdown.fontSize": {
          "type": "number",
          "default": 16,
          "description": "Base font size in pixels"
        },
        "any-markdown.imageDefaultDir": {
          "type": "string",
          "default": "",
          "description": "画像保存のデフォルトディレクトリ。空の場合はMarkdownファイルと同じディレクトリを使用。絶対パス（/path/to/dir）または相対パス（./images、images/）を指定可能。"
        },
        "any-markdown.forceRelativeImagePath": {
          "type": "boolean",
          "default": false,
          "description": "画像パスを常に相対パスで挿入します。絶対パスでimageDefaultDirを指定した場合でも、Markdownには相対パスが挿入されます。"
        },
        "any-markdown.language": {
          "type": "string",
          "enum": [
            "default",
            "en",
            "ja",
            "zh-TW",
            "zh-CN",
            "ko",
            "es",
            "fr"
          ],
          "default": "default",
          "description": "UI language. 'default' uses VS Code's display language. / UI言語。'default'はVS Codeの表示言語を使用します。"
        },
        "any-markdown.outlinerPageDir": {
          "type": "string",
          "default": "./pages",
          "description": "Outliner page files directory. Relative to .out file or absolute path. / アウトライナのページファイルディレクトリ。.outファイルからの相対パスまたは絶対パス。"
        },
        "any-markdown.outlinerPageTitle": {
          "type": "boolean",
          "default": false,
          "description": "Show page title input above the search bar in Outliner. / アウトライナの検索バー上部にタイトル入力欄を表示します。"
        },
        "any-markdown.toolbarMode": {
          "type": "string",
          "enum": [
            "full",
            "simple"
          ],
          "default": "simple",
          "description": "Toolbar display mode. 'full' shows all buttons. 'simple' shows only undo/redo and utility buttons (use Cmd+/ for other operations). / ツールバー表示モード。'full'は全ボタン表示。'simple'はundo/redoとユーティリティのみ（他はCmd+/で操作）。"
        },
        "any-markdown.linkOpenMode": {
          "type": "string",
          "enum": [
            "sidePanel",
            "tab"
          ],
          "default": "sidePanel",
          "description": "How to open linked Markdown files. 'sidePanel' opens in a Notion-style side peek panel. 'tab' opens in a new editor tab. / リンク先Markdownの開き方。'sidePanel'はNotion風サイドパネル。'tab'は新タブで開く。"
        },
        "any-markdown.enableDebugLogging": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging in the editor. Useful for troubleshooting. / エディタのデバッグログを有効にします。トラブルシューティングに便利です。"
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "any-markdown.insertTable",
          "when": "resourceLangId == markdown",
          "group": "anymd"
        },
        {
          "command": "any-markdown.insertToc",
          "when": "resourceLangId == markdown",
          "group": "anymd"
        }
      ],
      "explorer/context": [
        {
          "command": "any-markdown.openAsText",
          "when": "resourceLangId == markdown",
          "group": "navigation@99"
        },
        {
          "command": "any-markdown.compareAsText",
          "when": "resourceLangId == markdown",
          "group": "3_compare"
        }
      ],
      "editor/title/context": [
        {
          "command": "any-markdown.openAsText",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "any-markdown.addNotesFolder",
          "when": "view == notesExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "any-markdown.removeNotesFolder",
          "when": "view == notesExplorer",
          "group": "inline"
        }
      ]
    },
    "keybindings": [
      {
        "command": "any-markdown.undo",
        "key": "ctrl+z",
        "mac": "cmd+z",
        "when": "activeCustomEditorId == 'any-markdown.editor'"
      },
      {
        "command": "any-markdown.redo",
        "key": "ctrl+shift+z",
        "mac": "cmd+shift+z",
        "when": "!editorTextFocus"
      },
      {
        "command": "any-markdown.redo",
        "key": "ctrl+y",
        "mac": "cmd+y",
        "when": "!editorTextFocus"
      },
      {
        "command": "any-markdown.toggleSourceMode",
        "key": "ctrl+.",
        "mac": "cmd+.",
        "when": "activeCustomEditorId == 'any-markdown.editor'"
      },
      {
        "command": "any-markdown.openAsText",
        "key": "ctrl+shift+.",
        "mac": "cmd+shift+.",
        "when": "activeCustomEditorId == 'any-markdown.editor'"
      },
      {
        "command": "any-markdown.scopeOut",
        "key": "ctrl+shift+]",
        "mac": "cmd+shift+]",
        "when": "activeCustomEditorId == 'any-markdown.outliner'"
      },
      {
        "command": "any-markdown.scopeIn",
        "key": "ctrl+]",
        "mac": "cmd+]",
        "when": "activeCustomEditorId == 'any-markdown.outliner'"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && node build-locales.js && node scripts/copy-webview.js && node scripts/copy-vendor.js",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "test:build": "node test/build-standalone.js",
    "test:e2e": "npm run test:build && playwright test",
    "test:e2e:ui": "npm run test:build && playwright test --ui",
    "test:serve": "npx serve test/html -p 3000",
    "build:locales": "node build-locales.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "jsdom": "^27.4.0",
    "serve": "^14.2.5",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "katex": "^0.16.9",
    "mermaid": "^10.6.0",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2"
  }
}
